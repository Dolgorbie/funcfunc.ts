{
  "name": "funcfunc",
  "version": "0.0.1",
  "description": "functional programing framework",
  "author": "Kuwabiraki Yûki",
  "license": "MIT",
  "type": "module",
  "main": "./dist/main.js",
  "exports": {
    ".": {
      "default": "./dist/main.js",
      "import": "./dist/main.js"
    },
    "./*": {
      "default": "./dist/lib/*.js",
      "import": "./dist/lib/*.js"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-multi-entry": "^7.1.0",
    "@rollup/plugin-terser": "^1.0.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "rollup": "^4.60.4",
    "vitest": "^4.1.7"
  }
}
